# Chemin SQLite local (resolu depuis la racine du projet, meme fichier que
# celui utilise par la CLI Prisma via prisma.config.ts / prisma/.env).
#
# Pour partager les donnees avec l'equipe (memes campagnes/leads visibles par
# tout le monde), remplacer par une base Turso partagee, cf. README section
# "Partager les donnees avec l'equipe (Turso)" :
# DATABASE_URL="libsql://<db>-<org>.turso.io?authToken=<token>"
DATABASE_URL="file:./dev.db"

# URL du service gosom/google-maps-scraper (docker-compose)
GOSOM_API_URL="http://localhost:8080"

# Clé gratuite Google Cloud Console (PageSpeed Insights API)
PSI_API_KEY=""

# Clé gratuite OpenPageRank (https://www.domcop.com/openpagerank/)
OPENPAGERANK_API_KEY=""

# Clé gratuite Pappers.fr (100 requetes/mois) avec une email pro (ex: nathan.portier@mobem-solutions.com) pas gmail
PAPPERS_API_KEY=""
PAPPERS_MONTHLY_LIMIT=100

# Integration Notion (gratuite) : creer sur https://www.notion.so/my-integrations,
# puis partager la base cible avec l'integration (menu "..." de la base -> Connexions).
NOTION_API_KEY=""

# ID de la base Notion "Prospects" (visible dans son URL, cf. README pour la methode d'extraction).
NOTION_DATABASE_ID=""
